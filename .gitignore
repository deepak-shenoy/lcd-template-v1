# -------------------------------------------------------
# STM32CubeIDE / STM32CubeMX .gitignore
# -------------------------------------------------------

# Intellij
*.idea/

# OSX (Mac)
**/.DS_Store
*.DS_Store

# -------------------------------------------------------
# Build Output
# -------------------------------------------------------
Debug/
Release/
build/
*.elf
*.bin
*.hex
*.map
*.lst
*.su
*.d
*.o
*.a

# -------------------------------------------------------
# STM32CubeIDE Eclipse Settings
# -------------------------------------------------------
.metadata/
.settings/
.cproject
.project
*.launch
RemoteSystemsTempFiles/

# -------------------------------------------------------
# STM32CubeMX Generated
# -------------------------------------------------------
*.mxproject
# Uncomment below if you want to exclude generated code
# Core/Src/main.c is usually kept in source control
# *.ioc files ARE important — keep them tracked

# -------------------------------------------------------
# IDE & Editor Temp Files
# -------------------------------------------------------
*.bak
*.tmp
*~
*.swp
*.swo
.DS_Store
Thumbs.db

# -------------------------------------------------------
# Compiler / Toolchain
# -------------------------------------------------------
*.i
*.s
*.ii
*.gcno
*.gcda
*.gcov

# -------------------------------------------------------
# Linker
# -------------------------------------------------------
*.ld.bak

# -------------------------------------------------------
# OpenOCD / Debugger
# -------------------------------------------------------
*.cfg.bak
openocd.log

# -------------------------------------------------------
# Eclipse Workspace (if workspace is inside project)
# -------------------------------------------------------
workspace/
.recommenders/

# -------------------------------------------------------
# JLink / STLink Logs
# -------------------------------------------------------
JLinkLog.txt
JLinkSettings.ini
STLink/

# -------------------------------------------------------
# Python / Scripts (if any build scripts present)
# -------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.env
venv/

# -------------------------------------------------------
# VS Code (if used alongside CubeIDE)
# -------------------------------------------------------
.vscode/
*.code-workspace

# -------------------------------------------------------
# CLion (if used alongside CubeIDE)
# -------------------------------------------------------
.idea/
cmake-build-*/
CMakeLists.txt.bak

# -------------------------------------------------------
# Doxygen
# -------------------------------------------------------
docs/html/
docs/latex/
Doxyfile.bak

# -------------------------------------------------------
# Test / Coverage Output
# -------------------------------------------------------
coverage/
test_output/
*.coverage
